{
  "name": "backup-app",
  "version": "1.0.0",
  "description": "Config-first backup runner for local, network, SSH, MTP, and browser bookmark sources.",
  "type": "module",
  "main": "dist-node/main.js",
  "scripts": {
    "build:node": "node -e \"require('node:fs').rmSync('dist-node',{recursive:true,force:true})\" && tsc -p tsconfig.node.json",
    "build:renderer": "vite build",
    "build": "npm run build:node && npm run build:renderer",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "backup": "tsx src/cli/index.ts",
    "backup:example": "tsx src/cli/index.ts --config ./backup.tasks.example.js",
    "bundle": "esbuild src/cli/index.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/backup-script.bundle.cjs",
    "start": "npm run forge-start",
    "preforge-start": "npm run build",
    "preforge-package": "npm run build",
    "preforge-make": "npm run build",
    "forge-start": "cross-env ELECTRON_DISABLE_GPU=1 LIBGL_ALWAYS_SOFTWARE=1 electron-forge start",
    "forge-package": "electron-forge package",
    "forge-package:win": "electron-forge package --platform=win32 --arch=x64",
    "forge-make": "electron-forge make",
    "forge-make:win": "electron-forge make --platform=win32 --arch=x64"
  },
  "keywords": [
    "backup",
    "zip",
    "ssh",
    "mtp",
    "bookmarks"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@chakra-ui/react": "^3.35.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "archiver": "^7.0.1",
    "archiver-zip-encrypted": "^2.0.0",
    "cli-progress": "^3.12.0",
    "commander": "^14.0.1",
    "date-fns": "^4.1.0",
    "electron-squirrel-startup": "^1.0.1",
    "fast-glob": "^3.3.3",
    "framer-motion": "^12.40.0",
    "inquirer": "^14.0.0",
    "lodash.kebabcase": "^4.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "ssh2-sftp-client": "^12.0.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron/fuses": "^1.8.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.0",
    "cross-env": "^10.1.0",
    "electron": "^42.3.0",
    "esbuild": "^0.27.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "wait-on": "^9.0.10"
  }
}
